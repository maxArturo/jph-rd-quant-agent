# RD-Agent LLM backend (US-004). Values here are PLACEHOLDERS — real keys are
# injected per-request by the OneCLI proxy and must never live in this repo.
# Run anything that talks to a provider through the proxy:
#   onecli run --agent rdq-research -- <cmd>
# Stack is OpenAI-free: chat via Anthropic, embeddings via Voyage AI (both
# first-class LiteLLM providers; see docs/decisions.md).
CHAT_MODEL=anthropic/claude-sonnet-5
EMBEDDING_MODEL=voyage/voyage-3.5-lite
ANTHROPIC_API_KEY=placeholder-injected-by-onecli-proxy
VOYAGE_API_KEY=placeholder-injected-by-onecli-proxy
